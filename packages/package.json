{
  "name": "@reporter/core",
  "version": "1.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./drizzle-orm": {
      "types": "./dist/drizzle-orm/index.d.ts",
      "default": "./dist/drizzle-orm/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "tsx ../ops/database/migrate.ts"
  },
  "dependencies": {
    "@types/express": "^4.17.21",
    "drizzle-orm": "^0.45.0",
    "express": "^4.19.2",
    "express-validator": "^7.3.1",
    "jsonwebtoken": "^9.0.3",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/jest": "^30.0.0",
    "@types/supertest": "^6.0.3",
    "drizzle-kit": "^0.31.8",
    "jest": "^30.2.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
