# ------------------------------------------------------------------------------------------------
# Development environment variables template for local dev app of cl-reporter project
#
# @since agentic-flow--JP
# ------------------------------------------------------------------------------------------------

##
# LOCAL DEV CONFIG
# --------------------------
HOST_DOMAIN: {{ host_domain }}
JWT_SIGNING_KEY: {{ jwt_secret }}

##
# CLOVER API CONFIG
# --------------------------
CLOVER_CLIENT_ID:
CLOVER_CLIENT_SECRET:
CLOVER_OAUTH_AUTHORIZE_BASE: https://sandbox.dev.clover.com
# Must match Clover REST config. Use https when ingress serves TLS; for plain HTTP local dev set to http://{{ host_domain }}/start.
CLOVER_REDIRECT_URI: http://{{ host_domain }}/start
CLOVER_OAUTH_TOKEN_BASE: https://apisandbox.dev.clover.com
CLOVER_TOKEN_ENCRYPTION_KEY: {{ clover_token_encryption_key }}

##
# DATABASE CONFIG
# --------------------------
DATABASE_USER: db_user
DATABASE_PASSWORD: "111111"

##
# RABBITMQ CONFIG
# --------------------------
RABBITMQ_PASSWORD: "{{ rabbitmq_password | default('reporter-dev-rabbitmq') }}"

##
# CLUSTER CONFIG
# --------------------------
# Hard coded for ingress-nginx controller service (http://<service-name>.<namespace>.svc.cluster.local)
SERVER_API_BASE_URL: http://ingress-nginx-controller.ingress-nginx.svc.cluster.local