{
  "name": "oauth-api",
  "version": "1.0.0",
  "description": "OAuth API for Clover Reporter app",
  "main": "index.js",
  "scripts": {
    "start": "ts-node-dev src/index.ts",
    "start:prod": "node dist/index.js",
    "build": "tsc",
    "test": "jest --watchAll --no-cache",
    "test:ci": "jest --ci",
    "test:integration": "jest --ci --config jest.integration.config.cjs"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "<rootDir>/tests/int/"
    ],
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts"
    ],
    "setupFilesAfterEnv": [
      "./tests/JestSetup.ts"
    ]
  },
  "repository": {
    "type": "git",
    "url": "cl-reporter"
  },
  "author": "1ntellijosh",
  "license": "ISC",
  "dependencies": {
    "@reporter/common": "*",
    "@reporter/middleware": "*",
    "@types/express": "^4.17.21",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^0.10.9",
    "axios": "^1.13.4",
    "drizzle-orm": "^0.45.0",
    "express": "^4.19.2",
    "express-validator": "^7.3.1",
    "postgres": "^3.4.7",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.13.0",
    "@types/amqplib": "^0.10.8",
    "@types/jest": "^30.0.0",
    "@types/supertest": "^6.0.3",
    "drizzle-kit": "^0.31.8",
    "jest": "^30.2.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6"
  }
}
